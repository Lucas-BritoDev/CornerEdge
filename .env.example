# CornerEdge - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ─── API Football ────────────────────────────────────────────────────────────
EXPO_PUBLIC_API=sua-chave-api-football

# ─── RevenueCat (pagamentos in-app) ─────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_API_KEY=sua-chave-revenuecat

# ─── Google Play ─────────────────────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.corneredge.app
